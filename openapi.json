{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Basic welcome message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "Hello World!"
                }
              }
            }
          }
        },
        "summary": "Root endpoint",
        "tags": [
          "app"
        ]
      }
    },
    "/auth/users": {
      "get": {
        "description": "Mengambil daftar seluruh pengguna. Hanya bisa diakses oleh Admin.",
        "operationId": "AuthController_findAllUsers",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Berhasil mengambil daftar pengguna",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string",
                        "nullable": true
                      },
                      "email": {
                        "type": "string"
                      },
                      "role": {
                        "type": "string",
                        "example": "CUSTOMER"
                      },
                      "createdAt": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token tidak valid atau tidak ada"
          },
          "403": {
            "description": "Hanya Admin yang bisa mengakses"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Daftar semua pengguna (Admin)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/register/admin": {
      "post": {
        "description": "Membuat akun admin baru dengan email dan password. Hanya bisa diakses oleh Admin.",
        "operationId": "AuthController_createAdmin",
        "parameters": [],
        "responses": {
          "201": {
            "description": "Registrasi berhasil"
          },
          "400": {
            "description": "Email sudah terdaftar atau validasi gagal"
          },
          "403": {
            "description": "Hanya Admin yang bisa mengakses"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Registrasi admin baru (Admin)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/register/customer": {
      "post": {
        "description": "Membuat akun pelanggan baru dengan email dan password. Email harus unik.",
        "operationId": "AuthController_createCustomer",
        "parameters": [],
        "responses": {
          "201": {
            "description": "Registrasi berhasil"
          },
          "400": {
            "description": "Email sudah terdaftar atau validasi gagal"
          }
        },
        "summary": "Registrasi pelanggan baru",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "description": "Autentikasi dengan email dan password. Mengembalikan JWT access token.",
        "operationId": "AuthController_login",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Login berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIs..."
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "clxxxxxxxxxxxxxxxxxxxxxxxxx"
                        },
                        "email": {
                          "type": "string",
                          "example": "user@example.com"
                        },
                        "role": {
                          "type": "string",
                          "example": "ADMIN"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Email atau password salah"
          }
        },
        "summary": "Login pengguna",
        "tags": [
          "Auth"
        ]
      }
    },
    "/products": {
      "get": {
        "description": "Mengambil daftar produk aktif dengan pagination dan filter berdasarkan kategori, warna, ukuran, dan rentang harga.",
        "operationId": "ProductController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Berhasil mengambil daftar produk"
          }
        },
        "summary": "Daftar produk (Publik)",
        "tags": [
          "Products"
        ]
      },
      "post": {
        "description": "Membuat produk baru (type=PRODUCT) atau menambah varian/SKU ke produk yang sudah ada (type=SKU). Hanya Admin yang bisa mengakses.",
        "operationId": "ProductController_create",
        "parameters": [],
        "responses": {
          "201": {
            "description": "Produk/SKU berhasil dibuat"
          },
          "400": {
            "description": "Validasi gagal atau slug/SKU duplikat"
          },
          "401": {
            "description": "Token tidak valid atau tidak ada"
          },
          "403": {
            "description": "Hanya Admin yang bisa mengakses"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Buat produk atau SKU baru (Admin)",
        "tags": [
          "Products"
        ]
      }
    },
    "/products/all": {
      "get": {
        "description": "Mengambil semua produk aktif dan kategori aktif tanpa filter.",
        "operationId": "ProductController_listAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Berhasil mengambil semua produk dan kategori"
          }
        },
        "summary": "Daftar semua produk dan kategori aktif (Publik)",
        "tags": [
          "Products"
        ]
      }
    },
    "/products/{slug}": {
      "get": {
        "description": "Mengambil detail produk berdasarkan slug, termasuk SKU dan inventory.",
        "operationId": "ProductController_detail",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "description": "Slug produk",
            "schema": {
              "example": "sepatu-running-hitam"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mengambil detail produk"
          },
          "404": {
            "description": "Produk tidak ditemukan atau tidak aktif"
          }
        },
        "summary": "Detail produk (Publik)",
        "tags": [
          "Products"
        ]
      }
    },
    "/products/{id}": {
      "patch": {
        "description": "Mengupdate data produk. Gunakan type=PRODUCT atau kosongkan type.",
        "operationId": "ProductController_updateProduct",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "ID produk (CUID)",
