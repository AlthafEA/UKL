          "401": {
            "description": "Token tidak valid atau tidak ada"
          },
          "403": {
            "description": "Hanya Admin yang bisa mengakses"
          },
          "404": {
            "description": "Produk tidak ditemukan"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Update produk (Admin)",
        "tags": [
          "Products"
        ]
      },
      "delete": {
        "description": "Menghapus produk beserta semua SKU dan inventory terkait.",
        "operationId": "ProductController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "ID produk (CUID)",
            "schema": {}
          }
        ],
        "responses": {
          "200": {
            "description": "Produk berhasil dihapus"
          },
          "401": {
            "description": "Token tidak valid atau tidak ada"
          },
          "403": {
            "description": "Hanya Admin yang bisa mengakses"
          },
          "404": {
            "description": "Produk tidak ditemukan"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Hapus produk (Admin)",
        "tags": [
          "Products"
        ]
      }
    },
    "/products/{id}/image": {
      "post": {
        "description": "Upload gambar produk ke Cloudinary. File dikirim sebagai multipart/form-data.",
        "operationId": "ProductController_uploadImage",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "ID produk (CUID)",
