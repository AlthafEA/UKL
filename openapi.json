          "401": {
            "description": "Token tidak valid atau tidak ada"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Checkout / buat pesanan baru",
        "tags": [
          "Orders"
        ]
      }
    },
