  "info": {
    "title": "UKL Backend API",
    "description": "REST API untuk aplikasi e-commerce UKL. Dibangun dengan NestJS + Prisma + MySQL. Gunakan endpoint `/auth/login` untuk mendapatkan JWT token, lalu klik tombol **Authorize** di atas dan masukkan token.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Registrasi & Login pengguna"
    },
    {
      "name": "Categories",
