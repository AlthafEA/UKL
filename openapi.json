    "/orders/{id}/payment-proof": {
      "post": {
        "description": "Upload bukti transfer untuk pesanan yang masih PENDING. Setelah upload, status pesanan berubah menjadi WAITING_CONFIRMATION. File dikirim sebagai multipart/form-data.",
        "operationId": "OrderController_uploadProof",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "ID pesanan (CUID)",
            "schema": {}
          }
        ],
        "requestBody": {
          "required": true,
          "description": "File bukti pembayaran dan catatan opsional",
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File bukti transfer (JPG/PNG)"
                  },
                  "note": {
                    "type": "string",
                    "description": "Catatan opsional",
                    "example": "Transfer via BCA a/n Budi"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bukti pembayaran berhasil diupload"
          },
          "400": {
            "description": "Pesanan bukan PENDING atau bukti sudah diupload"
          },
          "401": {
            "description": "Token tidak valid atau tidak ada"
          },
          "403": {
            "description": "Pesanan bukan milik user ini"
          },
          "404": {
            "description": "Pesanan tidak ditemukan"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "Upload bukti pembayaran",
        "tags": [
          "Orders"
        ]
      }
    },
